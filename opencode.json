{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@franlol/opencode-md-table-formatter@0.0.3",
  ],
  "default_agent": "commit-drafter",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "figma-mcp-dektop": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp"
    },
  },
  "permission": {
    "*": "allow",
    "bash": {
      "*": "ask",
      "git *": "allow",
      "git commit *": "allow",
      "cat *": "allow",
      "pnpm *": "allow",
      "grep *": "allow"
    },
    "doom_loop": "ask",
    "external_directory": "ask"
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3:8b": {
          "name": "qwen3:8b"
        },
        "hoangquan456/qwen3-nothink:8b": {
          "name": "hoangquan456/qwen3-nothink:8b"
        },
        "minimax-m2.5:cloud": {
          "name": "minimax-m2.5:cloud"
        },
        "glm-5:cloud": {
          "name": "glm-5:cloud"
        },
        "glm-4.7:cloud": {
          "name": "glm-4.7:cloud"
        },
        "qwen3-coder-next:cloud": {
          "name": "qwen3-coder-next:cloud"
        },
        "qwen3.5:cloud": {
          "name": "qwen3.5:cloud"
        },
        "qwen3.5:2b": {
          "name": "qwen3.5:2b"
        },
        "deepseek-v3.2:cloud": {
          "name": "deepseek-v3.2:cloud"
        }
      }
    }
  }
}
